# Optional slack_app overrides. Shared config (database, Auth0, SERVER_URL)
# is loaded from the repo root .env — see /.env.example.

# Slack app credentials (from https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Override only if slack_app runs on a different host than repo root SERVER_URL
# SERVER_URL=http://localhost:8000

# LangGraph / Aegra Agent Protocol URL (where slack handlers invoke graphs)
LANGGRAPH_API_URL=http://localhost:8000
