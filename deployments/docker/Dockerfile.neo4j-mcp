# Remote Neo4j MCP (mcp-neo4j-cypher HTTP) — run alongside Aegra when agents need graph tools.
FROM python:3.12-slim-bookworm

WORKDIR /workspace

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock /workspace/
COPY graph_service /workspace/graph_service/

RUN uv sync --frozen --package aegra-graph-service --no-dev

ENV PATH="/workspace/.venv/bin:$PATH"

EXPOSE 8811

WORKDIR /workspace

CMD ["uv", "run", "--package", "aegra-graph-service", "neo4j-mcp-remote"]
