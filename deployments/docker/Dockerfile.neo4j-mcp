# HTTP Neo4j MCP (mcp-neo4j-cypher) — run alongside Neo4j when agents need graph tools.
FROM python:3.12-slim-bookworm

WORKDIR /workspace

RUN pip install --no-cache-dir uv

COPY pyproject.toml uv.lock /workspace/
COPY neo4j_mcp /workspace/neo4j_mcp/

RUN uv sync --frozen --package aegra-neo4j-mcp --no-dev

ENV PATH="/workspace/.venv/bin:$PATH"

EXPOSE 8811

WORKDIR /workspace

CMD ["uv", "run", "--package", "aegra-neo4j-mcp", "neo4j-mcp-remote"]
