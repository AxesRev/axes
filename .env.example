# --- Application Settings ---
PROJECT_NAME=Aegra
VERSION="0.1.0"
DEBUG=true

# [MANDATORY] Path to the main agent configuration file
AEGRA_CONFIG=aegra.json

# --- Database ---
# Option 1: Single connection string (standard for containers/cloud)
# DATABASE_URL=postgresql://user:password@host:5432/aegra
#
# Option 2: Individual fields (used when DATABASE_URL is not set)
POSTGRES_DB=aegra
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
POSTGRES_USER=user
DB_ECHO_LOG=false

# --- Connection Pools ---
# SQLAlchemy (Metadata & App)
SQLALCHEMY_POOL_SIZE=2
SQLALCHEMY_MAX_OVERFLOW=0

# LangGraph (Agent Runtime)
LANGGRAPH_MIN_POOL_SIZE=1
LANGGRAPH_MAX_POOL_SIZE=6

# --- Authentication ---
AUTH_TYPE=noop
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000
SERVER_URL=http://localhost:8000
LANGGRAPH_API_URL=http://localhost:8000

# --- Logging ---
LOG_LEVEL=INFO
ENV_MODE=LOCAL # DEVELOPMENT, PRODUCTION, LOCAL (PRODUCTION outputs JSON logs)
LOG_VERBOSITY=standard # standard, verbose (verbose outputs request-id)

# --- Documentation corpus (RAG / pgvector) ---
# OPENAI_API_KEY is shared with LLM usage when unset here; DocCorpusSettings reads the same env name.
# GitHub docs CLI (`python -m app_integrations.github`): path to a .zip of markdown files (see GITHUB_DOCS_ZIP_PATH below).
FIRECRAWL_API_KEY=
# Default: https://api.firecrawl.dev/v2
# FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v2
DOCS_EMBED_MODEL=text-embedding-3-small
DOCS_EMBED_DIMENSIONS=1536
DOCS_CHUNK_MAX_CHARS=2000
DOCS_CHUNK_OVERLAP_CHARS=200
# Firecrawl crawl (optional multi-page ingest via ingest_documentation_source)
# DOCS_CRAWL_PAGE_LIMIT=10000
# DOCS_CRAWL_POLL_INTERVAL_SEC=3
# DOCS_CRAWL_MAX_WAIT_SEC=7200
# react_agent: semantic chat retrieval searches doc_embedding_chunks by collection_key across all application values.
# DOC_CORPUS_COLLECTION_KEY=default
# DOC_CORPUS_TOP_K=6

# --- LLM Providers ---
OPENAI_API_KEY=sk-...

# --- GitHub context (react_agent) ---
# Ingest GitHub Docs into doc_embedding_chunks: set PYTHONPATH to repo root, then:
#   uv run python -m app_integrations.github
# Requires GITHUB_DOCS_ZIP_PATH (path to .zip of UTF-8 .md files; pages usually have YAML frontmatter with title:, else first # heading or filename stem)
# and OPENAI_API_KEY from the documentation corpus section above.
# GITHUB_DOCS_ZIP_PATH=D:/coding/project/github_docs.zip
# Legacy service PAT (unused).
GITHUB_PAT=

# --- Neo4j MCP (remote HTTP) — react_agent graph service ---
# Base URL only (no path); the agent calls {NEO4J_MCP_HOST}/mcp/ for read_neo4j_cypher and get_neo4j_schema.
# load_user_context also uses read_neo4j_cypher on this server to fetch user groups and permissions.
#
# Pick one (uncomment / copy into NEO4J_MCP_HOST below):
# - Local API + MCP on same machine (uvicorn outside Docker): http://127.0.0.1:8811
# - Docker Compose API + neo4j-mcp service (--profile neo4j): leave unset (compose defaults to http://neo4j-mcp:8811) or set explicitly:
#   NEO4J_MCP_HOST=http://neo4j-mcp:8811
# - Docker API but MCP on host (published port): http://host.docker.internal:8811  (Windows/macOS)
NEO4J_MCP_HOST=
NEO4J_MCP_PUBLISH_PORT=8811

# Published ports when Neo4j runs via Compose (`docker compose --profile neo4j up` or graph_service/docker-compose.yml).
NEO4J_PUBLISH_HTTP=7474
NEO4J_PUBLISH_BOLT=7687

# --- Neo4j MCP server / graph_service (Bolt — NOT sent to the agent) ---
# Used by `neo4j-mcp-remote` and graph fetchers (`fetch-graph` / integrations.fetcher). `get_neo4j_schema` needs APOC:
# https://neo4j.com/docs/apoc/current/installation/
#
# Host-native MCP (`uv run neo4j-mcp-remote`) + Compose Neo4j: bolt://localhost:${NEO4J_PUBLISH_BOLT:-7687}
# Compose overrides `NEO4J_URI` to bolt://neo4j:7687 for the neo4j-mcp container automatically.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# --- GitHub OAuth (Slack user → GitHub account linking) ---
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL: ${SERVER_URL}/auth/github/callback
# Scopes requested: read:user, user:email (stores github user id + primary verified email only)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Long random secret used to HMAC-sign the OAuth state parameter.
# Generate with: openssl rand -hex 32
GITHUB_OAUTH_STATE_SECRET=

# --- Slack app (slack_app package; optional overrides in slack_app/.env) ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# For `uv run python slack_app/deploy_manifest.py` (apps.manifest.update)
SLACK_APP_ID=
SLACK_APP_CONFIG_TOKEN=
# Where slack handlers call LangGraph (core Aegra API)
LANGGRAPH_API_URL=http://localhost:8000

# --- GitHub App (webapp install, graph_service fetcher, grant execution) ---
# Graph fetcher reads installation_id per tenant from app_integrations (app_name=github).
# Create at: https://github.com/settings/apps
# Setup URL (post-install callback): ${SERVER_URL}/auth/github/callback
# OAuth callback (Slack identity linking): same path — routed by presence of ?code=
# Same app ID/key used by graph_service/src/integrations/github/settings.py and app_integrations/github.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
# App slug only — e.g. axesjit from https://github.com/apps/axesjit (not the full URL).
GITHUB_APP_SLUG=
# Long random secret used to HMAC-sign the install state parameter.
# Generate with: openssl rand -hex 32
GITHUB_INSTALL_STATE_SECRET=
# Where users land after completing GitHub App installation in the browser.
WEBAPP_URL=http://localhost:3000

# --- Salesforce AxesRev package + JWT ---
# Optional overrides (defaults: package 04tg50000008CgjAAE, key path below, login.salesforce.com).
# SALESFORCE_PACKAGE_VERSION_ID=04tg50000008CgjAAE
# Signs tenant return URL; defaults to GITHUB_INSTALL_STATE_SECRET when unset.
# SALESFORCE_INSTALL_STATE_SECRET=
# External Client App consumer key and integration user for JWT Bearer flow.
SALESFORCE_CLIENT_ID=
SALESFORCE_PRIVATE_KEY_PATH=graph_service/certs/salesforce/AxesRev.key
SALESFORCE_LOGIN_URL=https://login.salesforce.com
# Per-tenant org_id and integration_username live in app_integrations after /auth/salesforce/complete.
# Optional comma-separated Share object API names to limit record-access ingest (e.g. AccountShare,ContactShare)
SALESFORCE_SHARE_OBJECTS=

# --- Observability (OpenTelemetry) ---
# Unified config for tracing. Supports multiple targets via Fan-out.
OTEL_SERVICE_NAME=aegra-backend
# Enable targets by comma-separated list: "LANGFUSE,PHOENIX,GENERIC"
# Leave empty to disable tracing.
OTEL_TARGETS=""
# Enable debug tracing to console (stdout)
OTEL_CONSOLE_EXPORT=false

# [Target: Langfuse]
# Note: uses LANGFUSE_BASE_URL (not HOST) to match SDK standards
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...

# [Target: Arize Phoenix]
# Default local endpoint shown
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_API_KEY=

# [Target: Generic OTLP]
# For Jaeger, Honeycomb, or other OTLP collectors
OTEL_EXPORTER_OTLP_ENDPOINT=
# Example headers: "Authorization=Bearer <token>,X-Custom=Value"
OTEL_EXPORTER_OTLP_HEADERS=

# --- Paddle billing (sandbox; card data stays at Paddle) ---
# API key from Paddle sandbox (contains _sdbx)
PADDLE_API_KEY=
# One-time usage price billed monthly via subscription charge (billing_cycle null)
PADDLE_USAGE_PRICE_ID=
# Tokens per usage unit when converting monthly token totals to Paddle quantity
BILLING_TOKENS_PER_UNIT=1000
# Webhook secret from Paddle sandbox (Developer tools > Notifications > destination)
PADDLE_WEBHOOK_SECRET=
# Monthly billing cron: uv run --package aegra-billing-service charge-usage
